pipeline {
    agent any

    environment {
        APP_DIR = 'zadanie_domowe_25'
        BUILD_DIR = 'build'
        DEPLOY_DIR = '/tmp/jenkins-deploy'
    }

    stages {
        stage('Checkout') {
            steps {
                echo 'Kod został pobrany z repozytorium GitHub przez SCM.'
                sh 'ls -la'
            }
        }

        stage('Build') {
            steps {
                dir("${APP_DIR}") {
                    sh '''
                        mkdir -p ${BUILD_DIR}
                        echo "To jest artefakt zbudowany przez Jenkins" > ${BUILD_DIR}/artifact.txt
                        date >> ${BUILD_DIR}/artifact.txt
                        cat ${BUILD_DIR}/artifact.txt
                    '''
                }
            }
        }

        stage('Test') {
            steps {
                dir("${APP_DIR}") {
                    sh '''
                        test -f ${BUILD_DIR}/artifact.txt
                        grep -q "To jest artefakt zbudowany przez Jenkins" ${BUILD_DIR}/artifact.txt
                        echo "Test zakończony sukcesem"
                    '''
                }
            }
        }

        stage('Deploy') {
            steps {
                dir("${APP_DIR}") {
                    sh '''
                        mkdir -p ${DEPLOY_DIR}
                        cp ${BUILD_DIR}/artifact.txt ${DEPLOY_DIR}/artifact.txt
                        echo "Plik wdrożony do ${DEPLOY_DIR}"
                        ls -l ${DEPLOY_DIR}
                    '''
                }
            }
        }
    }

    post {
        success {
            dir("${APP_DIR}") {
                sh '''
                    echo "STATUS: SUCCESS" > ${BUILD_DIR}/notification.txt
                    echo "JOB: ${JOB_NAME}" >> ${BUILD_DIR}/notification.txt
                    echo "BUILD NUMBER: ${BUILD_NUMBER}" >> ${BUILD_DIR}/notification.txt
                    echo "BUILD URL: ${BUILD_URL}" >> ${BUILD_DIR}/notification.txt
                    cat ${BUILD_DIR}/notification.txt
                '''
            }
            echo 'Pipeline zakończył się sukcesem.'
        }

        failure {
            dir("${APP_DIR}") {
                sh '''
                    mkdir -p ${BUILD_DIR}
                    echo "STATUS: FAILURE" > ${BUILD_DIR}/notification.txt
                    echo "JOB: ${JOB_NAME}" >> ${BUILD_DIR}/notification.txt
                    echo "BUILD NUMBER: ${BUILD_NUMBER}" >> ${BUILD_DIR}/notification.txt
                    echo "BUILD URL: ${BUILD_URL}" >> ${BUILD_DIR}/notification.txt
                    cat ${BUILD_DIR}/notification.txt
                '''
            }
            echo 'Pipeline zakończył się błędem.'
        }

        always {
            archiveArtifacts artifacts: 'zadanie_domowe_25/build/*', fingerprint: true
        }
    }
}
