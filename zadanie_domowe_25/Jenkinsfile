pipeline {
    agent any

    environment {
        APP_DIR = 'zadanie_domowe_25'
        BUILD_DIR = 'build'
        DEPLOY_DIR = '/tmp/jenkins-deploy-advanced'
        APP_VERSION = '2.0.0'
        TARGET_ENV = 'dev'
        ENABLE_DEPLOY = 'true'
        NOTIFY_EMAIL = 'twoj_mail@example.com'
        BUILD_STATUS = 'SUCCESS'
        COMMIT_AUTHOR = 'unknown'
        START_TIME = ''
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    try {
                        env.START_TIME = new Date().format("yyyy-MM-dd HH:mm:ss")
                        echo "Rozpoczęcie pipeline: ${env.START_TIME}"

                        checkout scm

                        env.COMMIT_AUTHOR = sh(
                            script: "git log -1 --pretty=format:'%an'",
                            returnStdout: true
                        ).trim()

                        echo "Autor ostatniej zmiany: ${env.COMMIT_AUTHOR}"
                    } catch (err) {
                        env.BUILD_STATUS = 'FAILURE'
                        echo "Błąd w etapie Checkout: ${err}"
                        error("Checkout failed")
                    }
                }
            }
        }

        stage('Build') {
            when {
                expression { env.BUILD_STATUS == 'SUCCESS' }
            }
            steps {
                script {
                    try {
                        dir("${env.APP_DIR}") {
                            sh '''
                                mkdir -p ${BUILD_DIR}
                                echo "Wersja aplikacji: ${APP_VERSION}" > ${BUILD_DIR}/artifact.txt
                                echo "Środowisko: ${TARGET_ENV}" >> ${BUILD_DIR}/artifact.txt
                                echo "Artefakt zbudowany przez Jenkins" >> ${BUILD_DIR}/artifact.txt
                                date >> ${BUILD_DIR}/artifact.txt
                                cat ${BUILD_DIR}/artifact.txt
                            '''
                        }
                    } catch (err) {
                        env.BUILD_STATUS = 'FAILURE'
                        echo "Błąd w etapie Build: ${err}"
                        error("Build failed")
                    }
                }
            }
        }

        stage('Test') {
            when {
                expression { env.BUILD_STATUS == 'SUCCESS' }
            }
            steps {
                script {
                    try {
                        dir("${env.APP_DIR}") {
                            sh '''
                                test -f ${BUILD_DIR}/artifact.txt
                                grep -q "Artefakt zbudowany przez Jenkins" ${BUILD_DIR}/artifact.txt
                                grep -q "Wersja aplikacji: ${APP_VERSION}" ${BUILD_DIR}/artifact.txt
                                echo "Testy zakończone sukcesem"
                            '''
                        }
                    } catch (err) {
                        env.BUILD_STATUS = 'FAILURE'
                        echo "Błąd w etapie Test: ${err}"
                        error("Test failed")
                    }
                }
            }
        }

        stage('Deploy') {
            when {
                expression { env.BUILD_STATUS == 'SUCCESS' && env.ENABLE_DEPLOY == 'true' }
            }
            steps {
                script {
                    try {
                        dir("${env.APP_DIR}") {
                            sh '''
                                mkdir -p ${DEPLOY_DIR}
                                cp ${BUILD_DIR}/artifact.txt ${DEPLOY_DIR}/artifact-${APP_VERSION}.txt
                                echo "Wdrożenie zakończone sukcesem do ${DEPLOY_DIR}"
                                ls -l ${DEPLOY_DIR}
                            '''
                        }
                    } catch (err) {
                        env.BUILD_STATUS = 'FAILURE'
                        echo "Błąd w etapie Deploy: ${err}"
                        error("Deploy failed")
                    }
                }
            }
        }
    }

    post {
        success {
            script {
                def endTime = new Date().format("yyyy-MM-dd HH:mm:ss")
                def message = """\
Pipeline zakończył się sukcesem.
Job: ${env.JOB_NAME}
Build: ${env.BUILD_NUMBER}
Wynik: SUCCESS
Autor zmian: ${env.COMMIT_AUTHOR}
Start: ${env.START_TIME}
Koniec: ${endTime}
URL: ${env.BUILD_URL}
""".stripIndent()

                echo message

                dir("${env.APP_DIR}") {
                    sh """
                        mkdir -p ${BUILD_DIR}
                        cat > ${BUILD_DIR}/notification.txt <<'EOF'
${message}
EOF
                    """
                }

                archiveArtifacts artifacts: 'zadanie_domowe_25/build/*', fingerprint: true

                try {
                    mail to: "${env.NOTIFY_EMAIL}",
                         subject: "SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                         body: message
                } catch (err) {
                    echo "Nie udało się wysłać e-maila: ${err}"
                    echo "Powiadomienie zostało zapisane w notification.txt"
                }
            }
        }

        failure {
            script {
                def endTime = new Date().format("yyyy-MM-dd HH:mm:ss")
                def message = """\
Pipeline zakończył się błędem.
Job: ${env.JOB_NAME}
Build: ${env.BUILD_NUMBER}
Wynik: FAILURE
Autor zmian: ${env.COMMIT_AUTHOR}
Start: ${env.START_TIME}
Koniec: ${endTime}
URL: ${env.BUILD_URL}
""".stripIndent()

                echo message

                dir("${env.APP_DIR}") {
                    sh """
                        mkdir -p ${BUILD_DIR}
                        cat > ${BUILD_DIR}/notification.txt <<'EOF'
${message}
EOF
                    """
                }

                archiveArtifacts artifacts: 'zadanie_domowe_25/build/*', fingerprint: true, onlyIfSuccessful: false

                try {
                    mail to: "${env.NOTIFY_EMAIL}",
                         subject: "FAILURE: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                         body: message
                } catch (err) {
                    echo "Nie udało się wysłać e-maila: ${err}"
                    echo "Powiadomienie zostało zapisane w notification.txt"
                }
            }
        }

        always {
            echo "Pipeline zakończył działanie. Status końcowy: ${currentBuild.currentResult}"
        }
    }
}
